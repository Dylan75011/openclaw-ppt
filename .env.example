PORT=3000
OUTPUT_DIR=./output

# 公网部署时设置，生成的下载链接会带上完整域名
# 例：http://1.2.3.4:3000 或 https://your-domain.com
PUBLIC_BASE_URL=

# ── 主力模型：MiniMax ──────────────────────────────────────────────
# Token Plan（sk-cp- 开头）订阅后可免费大量调用
# 同时用于：主模型对话、Web Search、AI 生图（image-01）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5

# ── 评审专用：DeepSeek-R1 ──────────────────────────────────────────
# 仅 Critic Agent 评审时调用，每次生成约 1–3 次，按量付费
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── 评审参数 ───────────────────────────────────────────────────────
CRITIC_PASS_SCORE=7.0
CRITIC_MAX_ROUNDS=3

# ── 网络搜索：优先级 阿里百炼 → Tavily ────────────────────────────
ALI_API_KEY=
TAVILY_API_KEY=

# ── 图片搜索：优先级 SerpAPI → Bing → Pexels ──────────────────────
# SerpAPI（首选）：中文查询走谷歌图片，英文走 Bing 图片
SERP_API_KEY=
# Bing Image Search（备选）：Azure 认知服务 key
BING_API_KEY=
# Pexels（兜底）：已内置免费 key，无需填写；填写后会覆盖内置 key
PEXELS_API_KEY=

# ── 网络代理（可选）──────────────────────────────────────────────
# 服务器无法直连 api.minimaxi.com 等境外 API 时设置
# 格式：http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
HTTPS_PROXY=
