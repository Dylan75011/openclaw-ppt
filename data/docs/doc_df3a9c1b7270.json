        "attrs": {
          "textAlign": null,
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "笔记③：「在字节，\"老黄牛\"还能\"活\"吗？」（31赞）"
          }
        ]
      },
      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "marks": [
              {
