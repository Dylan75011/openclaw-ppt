                  {
                    "type": "text",
                    "text": "：三区融合（体验+沉浸合并），保留核心转化功能"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
